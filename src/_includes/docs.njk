{# ABOUTME: Docs layout with expandable sidebar navigation. #}
{# ABOUTME: Used by the spec page for two-column documentation display. #}

{% extends "base.njk" %}

{% block content %}
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
  <div class="lg:grid lg:grid-cols-[14rem_1fr] lg:gap-10">

    <!-- Mobile menu button -->
    <button id="sidebar-toggle" class="lg:hidden fixed bottom-6 right-6 z-40 w-11 h-11 bg-zinc-900 text-white rounded-full shadow-lg flex items-center justify-center hover:bg-zinc-700 transition-colors" aria-label="Toggle navigation" aria-expanded="false" aria-controls="sidebar">
      <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M3 5h12M3 9h12M3 13h12"/></svg>
    </button>

    <!-- Sidebar overlay (mobile) -->
    <div id="sidebar-overlay" class="hidden fixed inset-0 bg-zinc-900/20 backdrop-blur-sm z-30 lg:hidden"></div>

    <!-- Sidebar -->
    <aside id="sidebar" class="hidden lg:block fixed lg:sticky top-14 z-30 lg:z-auto h-[calc(100vh-3.5rem)] w-64 lg:w-auto bg-white lg:bg-transparent border-r lg:border-r-0 border-zinc-900/5 overflow-y-auto py-8 px-4 lg:px-0" role="complementary" aria-label="Sidebar navigation">
      <nav aria-label="Specification sections">
        <ul class="list-none m-0 p-0 space-y-0.5 text-sm" role="tree">
          {% for section in spec.nav %}
          <li role="treeitem" {% if section.children.length > 0 %}aria-expanded="false"{% endif %}>
            <a href="#{{ section.id }}" class="nav-link flex items-center gap-1.5 py-1.5 px-2 rounded-lg text-zinc-600 hover:text-zinc-900 hover:bg-zinc-50 no-underline transition-colors" data-section="{{ section.id }}">
              {% if section.children.length > 0 %}
              <svg class="nav-chevron w-3 h-3 shrink-0 transition-transform text-zinc-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path d="M9 18l6-6-6-6"/></svg>
              {% endif %}
              <span class="{% if section.children.length == 0 %}ml-[1.125rem]{% endif %} truncate">{{ section.text }}</span>
            </a>
            {% if section.children.length > 0 %}
            <ul class="nav-children hidden list-none m-0 pl-[1.125rem] space-y-0" role="group">
              {% for child in section.children %}
              <li role="treeitem">
                <a href="#{{ child.id }}" class="nav-link block py-1 px-2 rounded-lg text-xs text-zinc-400 hover:text-zinc-900 hover:bg-zinc-50 no-underline transition-colors" data-section="{{ child.id }}">{{ child.text }}</a>
              </li>
              {% endfor %}
            </ul>
            {% endif %}
          </li>
          {% endfor %}
        </ul>
      </nav>
    </aside>

    <!-- Main content -->
    <div class="min-w-0 pt-16 pb-10" role="document">
      <article class="prose prose-zinc max-w-2xl
        prose-headings:tracking-tight prose-headings:text-zinc-900
        prose-h1:text-2xl prose-h1:font-bold prose-h1:mb-6
        prose-h2:text-lg prose-h2:font-semibold prose-h2:mt-14 prose-h2:mb-4 prose-h2:pt-8 prose-h2:border-t prose-h2:border-zinc-900/5
        prose-h3:text-base prose-h3:font-semibold prose-h3:mt-8 prose-h3:mb-3
        prose-h4:text-sm prose-h4:font-semibold prose-h4:mt-6 prose-h4:mb-2
        prose-p:text-[0.9375rem] prose-p:leading-7 prose-p:text-zinc-600
        prose-strong:text-zinc-900 prose-strong:font-semibold
        prose-a:text-emerald-500 prose-a:no-underline hover:prose-a:text-emerald-600
        prose-code:text-[0.8125rem] prose-code:bg-zinc-100 prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded-md prose-code:font-[family-name:var(--font-mono)] prose-code:text-zinc-800 prose-code:font-medium
        prose-pre:bg-zinc-900 prose-pre:text-zinc-300 prose-pre:rounded-xl prose-pre:text-[0.8125rem] prose-pre:leading-relaxed prose-pre:font-[family-name:var(--font-mono)]
        prose-table:text-sm
        prose-th:bg-zinc-50 prose-th:border prose-th:border-zinc-900/5 prose-th:px-3 prose-th:py-2 prose-th:font-semibold prose-th:text-zinc-900
        prose-td:border prose-td:border-zinc-900/5 prose-td:px-3 prose-td:py-2 prose-td:text-zinc-600
        prose-li:text-[0.9375rem] prose-li:leading-7 prose-li:text-zinc-600">
        {{ content | safe }}
      </article>
    </div>

  </div>
</div>

<script src="{{ '/js/docs.js' | url }}"></script>
{% endblock %}
